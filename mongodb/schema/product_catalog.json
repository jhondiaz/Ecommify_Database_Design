{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ecommify Enriched Product Catalog",
  "description": "Documento que combina metadatos de productos con reseñas para analítica y catálogo",
  "type": "object",
  "properties": {
    "product_id": { "type": "string", "description": "UUID proveniente de PostgreSQL" },
    "category_path": { 
      "type": "array", 
      "items": { "type": "string" },
      "description": "Ancestros de categoría para navegación breadcrumb"
    },
    "attributes": {
      "type": "object",
      "description": "Atributos dinámicos (Esquema flexible)",
      "additionalProperties": true
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "review_id": { "type": "string" },
          "score": { "type": "integer", "minimum": 1, "maximum": 5 },
          "comment": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "analytics_summary": {
      "type": "object",
      "properties": {
        "view_count": { "type": "integer" },
        "average_score": { "type": "number" },
        "total_sold": { "type": "integer" }
      }
    }
  }
}